# Required for JWT authentication
SECRET_KEY=change-me-to-random-secret

# PostgreSQL database connection (or sqlite:///local.db for local dev)
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:PORT/dbname

# OpenAI API for poster generation
OPENAI_API_KEY=your-openai-api-key

# Email configuration (Primary: Resend)
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=support@yourdomain.com

# SMTP fallback (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_STARTTLS=1

# Optional: Server port (defaults to 8080)
PORT=8080

# Upload settings
MAX_UPLOAD_MB=20
UPLOAD_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW_SEC=30
RATE_LIMIT_MAX_REQUESTS=6